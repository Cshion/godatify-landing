# ==============================================================================
# Backend Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Generate secure keys with: openssl rand -base64 32
# ==============================================================================

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
HOST=0.0.0.0
PORT=1337
NODE_ENV=development

# Public URL of THIS backend — used by Strapi to build absolute URLs
# (e.g. image URLs, admin panel links, API responses with self-links)
# - Development: http://localhost:1337
# - Production:  https://api.godatify.com
PUBLIC_URL=http://localhost:1337

# ------------------------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------------------------
# Options: sqlite (default for dev), postgres (recommended for production)
DATABASE_CLIENT=sqlite

# PostgreSQL settings (required when DATABASE_CLIENT=postgres)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=your-secure-password
DATABASE_SSL=false

# SQLite settings (for local development)
# DATABASE_FILENAME=.tmp/data.db

# Connection pool (for postgres)
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=50

# ------------------------------------------------------------------------------
# Security Keys (REQUIRED - generate with: openssl rand -base64 32)
# ------------------------------------------------------------------------------
APP_KEYS="toBeModified1,toBeModified2,toBeModified3,toBeModified4"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

# ------------------------------------------------------------------------------
# AWS S3 (Optional - for file uploads in production)
# ------------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_BUCKET=godatify-uploads

# ------------------------------------------------------------------------------
# Debug (disable in production)
# ------------------------------------------------------------------------------
# DATABASE_DEBUG=false  ⚠️ Not read by config — kept for reference, has no effect currently

# ------------------------------------------------------------------------------
# CORS (comma-separated list of allowed origins)
# ------------------------------------------------------------------------------
# CORS_ORIGINS=https://godatify.com,https://www.godatify.com

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
# Options: fatal, error, warn, info, debug, trace
# LOG_LEVEL=info
