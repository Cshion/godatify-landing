{
    "kind": "collectionType",
    "collectionName": "blog_posts",
    "info": {
        "singularName": "blog-post",
        "pluralName": "blog-posts",
        "displayName": "Blog Post",
        "description": "Blog articles and news"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "slug": {
            "type": "uid",
            "targetField": "title",
            "required": true
        },
        "excerpt": {
            "type": "text"
        },
        "content": {
            "type": "blocks"
        },
        "coverImageUrl": {
            "type": "string"
        },
        "coverImage": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "date": {
            "type": "date"
        },
        "readingTime": {
            "type": "string"
        },
        "featured": {
            "type": "boolean",
            "default": false
        },
        "author": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::author.author",
            "inversedBy": "blog_posts"
        },
        "tags": {
            "type": "json"
        }
    }
}