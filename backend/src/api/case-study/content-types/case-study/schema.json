{
    "kind": "collectionType",
    "collectionName": "case_studies",
    "info": {
        "singularName": "case-study",
        "pluralName": "case-studies",
        "displayName": "Case Study",
        "description": "Customer success stories"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "slug": {
            "type": "uid",
            "targetField": "title"
        },
        "industry": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::industry.industry",
            "inversedBy": "case_studies",
            "required": true
        },
        "client": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::client.client",
            "inversedBy": "case_studies"
        },
        "description": {
            "type": "text"
        },
        "challenge": {
            "type": "text"
        },
        "solution": {
            "type": "text"
        },
        "results": {
            "type": "json"
        },
        "techStack": {
            "type": "json"
        },
        "mainImage": {
            "type": "media",
            "allowedTypes": [
                "images",
                "files",
                "videos",
                "audios"
            ]
        },
        "mainImageUrl": {
            "type": "string"
        },
        "videoUrl": {
            "type": "string"
        },
        "testimonial": {
            "type": "relation",
            "relation": "oneToOne",
            "target": "api::testimonial.testimonial"
        },
        "industryName": {
            "type": "string"
        },
        "clientName": {
            "type": "string"
        },
        "clientLogoUrl": {
            "type": "string"
        },
        "clientWebsite": {
            "type": "string"
        },
        "testimonialQuote": {
            "type": "text"
        },
        "testimonialAuthor": {
            "type": "string"
        },
        "testimonialRole": {
            "type": "string"
        },
        "testimonialAuthorImageUrl": {
            "type": "string"
        },
        "testimonialLinkedIn": {
            "type": "string"
        }
    }
}